{
  "name": "ball-clash-arena",
  "version": "1.3.2",
  "private": true,
  "description": "Ball Clash Arena public-test HTML5 arena fighter with server-authoritative WebSocket multiplayer and release-grade performance controls.",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "check": "node --check server.js",
    "check:server": "node --check server.js",
    "check:client": "node -e \"const fs=require('fs');const s=fs.readFileSync('index.html','utf8');fs.writeFileSync('.client-check.js',s.split('<script>')[1].split('</script>')[0]);\" && node --check .client-check.js && node -e \"require('fs').rmSync('.client-check.js',{force:true})\"",
    "check:all": "npm run check:server && npm run check:client"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "UNLICENSED"
}
